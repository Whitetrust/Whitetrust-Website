{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/dashboard(?:\\/((?:[^\\/#\\?]+?)(?:\\/(?:[^\\/#\\?]+?))*))?(\\.json|\\.rsc|\\.segments\\/.+\\.segment\\.rsc)?[\\/#\\?]?$",
          "originalSource": "/dashboard/:path*"
        }
      ]
    },
    "/api/book": {},
    "/api/track": {},
    "/dashboard": {},
    "/dashboard/prospect/[token]": {},
    "/r/[token]": {}
  }
}